"@PROJECT_PATH@/assets/images/mg-1.jpg\" alt=\"Mobirise Website Builder\">\n                    </div>\n                    <div class=\"item-content card\">\n                        <div class=\"label-wrap\">\n                            <p class=\"card-label mbr-fonts-style\" data-app-selector=\".card-label, .label-wrap\" mbr-theme-style=\"display-4\" mbr-if=\"showCardLabel\">\n                                <b>In Miami</b>\n                            </p>\n                        </div>\n                        <h4 class=\"card-title mbr-fonts-style\" mbr-theme-style=\"display-5\" mbr-if=\"showCardTitle\" data-app-selector=\".card-title, .mbr-section-btn\"><b>Actividad 2:</b></h4>\n                        <p class=\"card-text mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showText\" data-app-selector=\".card-text\">Se organizará un debate. Un grupo defenderá el modelo actual del SGSSS y otro lo cuestionará. Cada equipo deberá preparar argumentos basados en datos, leyes y experiencias reales.<br></p>\n                        <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n                            <a class=\"btn btn-primary\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                <span class=\"mobi-mbri mobi-mbri-map-pin mbr-iconfont mbr-iconfont-btn\"></span>\n                                Miami, FL\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            \n        </div>\n    </div>\n</section>",
