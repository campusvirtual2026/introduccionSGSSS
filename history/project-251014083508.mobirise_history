H@/assets/images/1-bg.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"wrapper justify-content-center\">\n            <div class=\"left-col\">\n                <div class=\"row flex-column\">\n                    <div class=\"col-12 mb-2\">\n                        <div class=\"card\">\n                            <div class=\"card-body\">\n                                <img src=\"@PROJECT_PATH@/assets/images/red.svg\" alt=\"Mobirise\" class=\"card-img-top mb-3\" mbr-if=\"showImage\">\n                                <h3 class=\"card-title mbr-section-subtitle mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-section-subtitle\" data-app-placeholder=\"Type Text\" mbr-if=\"showTitle\"><b>Ventajas del modelo actual</b></h3>\n                                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list\" data-multiline mbr-article mbr-if=\"showList\">\n                                    <li><b>Cobertura casi universal:</b> la mayoría de los colombianos están afiliados al sistema.\n</li><li><b>Derecho garantizado: </b>la salud es reconocida como derecho fundamental, gracias a la Ley Estatutaria.\n</li><li><b>Diversidad de prestadores:</b> los usuarios pueden elegir entre opciones públicas y privadas.\n</li><li><b>Fondo único de recursos (ADRES):</b> centraliza y mejora la gestión de los pagos.</li>\n                                </ul>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"col-12 mb-2\" mbr-if=\"cardAmount > 2\">\n                        <div class=\"card\">\n                            <div class=\"card-body\">\n                                <img src=\"@PROJECT_PATH@/assets/images/blue.svg\" alt=\"Mobirise\" class=\"card-img-top mb-3\" mbr-if=\"showImage\">\n                                <h3 class=\"card-title mbr-section-subtitle mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-section-subtitle\" data-app-placeholder=\"Type Text\" mbr-if=\"showTitle\"><b>3.\tAuditoría digital:&nbsp;</b></h3>\n                                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list\" data-multiline mbr-article mbr-if=\"showList\">\n                                    <li>Link: https://www.cyberclick.es/numerical-blog/auditoria-de-marketing-digital-que-es-que-incluye-y-como-se-hace</li><li>Link: <a href=\"https://blog.hubspot.es/marketing/auditoria-marketing\" class=\"text-primary\" target=\"_blank\">https://blog.hubspot.es/marketing/auditoria-marketing</a></li>\n                                </ul>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"col-12\" mbr-if=\"cardAmount > 4\">\n                        <div class=\"card\">\n                            <div class=\"card-body\">\n                                <img src=\"@PROJECT_PATH@/assets/images/green.svg\" alt=\"Mobirise\" class=\"card-img-top mb-3\" mbr-if=\"showImage\">\n                                <h3 class=\"card-title mbr-section-subtitle mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-section-subtitle\" data-app-placeholder=\"Type Text\" mbr-if=\"showTitle\"><b>5.\tQué es una estrategia digital 360:&nbsp;</b></h3>\n                                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list\" data-multiline mbr-article mbr-if=\"showList\">\n                                    <li>https://lemon.digital/en-que-consiste-una-estrategia-de-marketing-digital-360/&nbsp;</li>\n                                </ul>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"right-col\">\n                <div class=\"row flex-column\">\n                    <div class=\"col-12 mb-2\">\n                        <div class=\"card\">\n                            <div class=\"card-body\">\n                                <img src=\"@PROJECT_PATH@/assets/images/orange.svg\" alt=\"Mobirise\" class=\"card-img-top mb-3\" mbr-if=\"showImage\">\n                                <h3 class=\"card-title mbr-section-subtitle mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-section-subtitle\" data-app-placeholder=\"Type Text\" mbr-if=\"showTitle\"><b>Desventajas</b></h3>\n                                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list\" data-multiline mbr-article mbr-if=\"showList\">\n                                    <li><b>Ineficiencia operativa:</b> las EPS suelen presentar demoras y barreras de acceso.\n</li><li><b>Casos de corrupción: </b>algunos recursos han sido mal manejados.\n</li><li><b>Desigualdad territorial:</b> no todas las zonas del país tienen el mismo nivel de atención.\n</li><li><b>Enfoque curativo más que preventivo:</b> hay poco énfasis en promoción de la salud.<br><br><br></li>\n                                </ul>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"col-12 mb-2\" mbr-if=\"cardAmount > 3\">\n                        <div class=\"card\">\n                            <div class=\"card-body\">\n                                <img src=\"@PROJECT_PATH@/assets/images/purple.svg\" alt=\"Mobirise\" class=\"card-img-top mb-3\" mbr-if=\"showImage\">\n                                <h3 class=\"card-title mbr-section-subtitle mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-section-subtitle\" data-app-placeholder=\"Type Text\" mbr-if=\"showTitle\"><b>4.\tAplicaciones digitales y de IA para auditoría:&nbsp;</b></h3>\n                                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list\" data-multiline mbr-article mbr-if=\"showList\">\n                                    <li>Para sitios web: <a href=\"https://wevo.ai/\" class=\"text-primary\" target=\"_blank\">https://wevo.ai/</a>\n</li><li>Para sitios web: <a href=\"https://www.similarweb.com/es/\" class=\"text-primary\" target=\"_blank\">https://www.similarweb.com/es/</a> \n</li><li>Para redes sociales: <a href=\"https://www.notjustanalytics.com/\" class=\"text-primary\" target=\"_blank\">https://www.notjustanalytics.com/</a></li>\n                                </ul>\n                            </div>\n                        </div>\n                    </div>\n                    <div class=\"col-12\" mbr-if=\"cardAmount > 5\">\n                        <div class=\"card\">\n                            <div class=\"card-body\">\n                                <img src=\"@PROJECT_PATH@/assets/images/cyan.svg\" alt=\"Mobirise\" class=\"card-img-top mb-3\" mbr-if=\"showImage\">\n                                <h3 class=\"card-title mbr-section-subtitle mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".mbr-section-subtitle\" data-app-placeholder=\"Type Text\" mbr-if=\"showTitle\">\n                                    <b>Flexible Attendance</b>\n                                </h3>\n                                <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list\" data-multiline mbr-article mbr-if=\"showList\">\n                                    <li>Phasellus eget arcu nec nulla viverra tristique.</li>\n                                    <li>Maecenas dapibus malesuada lacus vel ullamcorper.</li>\n                                    <li>Temporibus, explicabo, sed.</li>\n                                </ul>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
