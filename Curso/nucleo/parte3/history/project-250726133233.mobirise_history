llback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" checked condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#000000\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.5\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\">\n\n            <div class=\"card col-md-12\" mbr-class=\"{'col-lg-12': cardsAmount == 1, 'col-lg-6': cardsAmount == 2, 'col-lg-4': cardsAmount == 3}\">\n                <div class=\"card-wrap card1\">\n\n                    <div class=\"content-wrap align-left\">\n                        <h5 class=\"mbr-section-title card-title mbr-fonts-style align-left mb-3\" mbr-theme-style=\"display-5\" mbr-if=\"showName\" data-app-selector=\".card-title, .social-row\"><b>1. Accidente laboral en una fábrica: el papel de la ARL</b></h5>\n                        <h6 class=\"mbr-role mbr-fonts-style align-left mb-3\" mbr-theme-style=\"display-4\" mbr-if=\"showRole\" data-app-selector=\".mbr-role, .social-row\"><b>Subtitle</b></h6>\n                        <p class=\"card-text mbr-fonts-style align-left mb-4\" data-app-selector=\".card-text, .mbr-section-btn, .social-row\" mbr-theme-style=\"display-7\" mbr-if=\"showCardText\">\n                            En una planta de autopartes, un operario sufrió un accidente al quedar atrapada su mano en una prensa hidráulica, debido a una falla en el sistema de seguridad. La empresa informó de inmediato a la ARL, que se encargó de gestionar la atención médica, la incapacidad temporal y la compensación económica del trabajador. Además, la ARL lideró una investigación para identificar las causas del accidente, lo que llevó a implementar medidas correctivas como mejorar los sistemas de seguridad de las máquinas y capacitar al personal en prevención de riesgos. Este caso muestra cómo una adecuada gestión por parte de la ARL puede marcar la diferencia en la salud y protección de los trabajadores.\n                        </p>\n\n                        <div class=\"link-wrapper align-left\">\n                            <p class=\"mbr-link align-left mbr-fonts-style\" mbr-theme-style=\"display-7\" mbr-if=\"showButtons\" data-app-selector=\".mbr-link, .text-wrapper, path\"><b>READ MORE</b>\n                            </p>\n\n\n                            <svg class=\"svg1\" xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" version=\"1.1\" width=\"300\" height=\"50\" viewBox=\"0 0 300 50\" preserveAspectRatio=\"xMidYMid slice\" xml:space=\"preserve\">\n                                <defs>\n                                </defs>\n                                <g transform=\"matrix(1 0 0 1 200 4.59)\">\n                                    <g style>\n                                        <g transform=\"matrix(1 0 0 1 -125 0)\" id=\"aac4a38b-7b64-4b27-81f4-7cba1fc44311\">\n                                            <path style=\"stroke: rgb(23,0,59); stroke-width: 4; stroke-dasharray: none; stroke-linecap: butt; stroke-dashoffset: 0; stroke-linejoin: miter; stroke-miterlimit: 10; fill: none; fill-rule: nonzero; opacity: 1;\" transform=\" translate(-75, -4.59)\" d=\"M 100 2 a 8.825 8.825 0 0 0 -6.25 2.583 A 8.822 8.822 0 0 1 87.5 7.17 a 8.822 8.822 0 0 1 -6.25 -2.584 a 8.853 8.853 0 0 0 -12.5 0 a 8.851 8.851 0 0 1 -12.5 0 A 8.825 8.825 0 0 0 50 2\" st